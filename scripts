function doPost(e) {
  try {
    var startTime = new Date().getTime();
    Logger.log("=== DÉBUT DO POST ARBITRE ===");

    if (!e?.postData?.contents) {
      return createErrorResponse("Données manquantes", "MISSING_DATA");
    }

    if (e.postData.contents.length > 8000000) {
      return createErrorResponse("Données trop volumineuses (max 3 Mo pour l'image)", "DATA_TOO_LARGE");
    }

    var data;
    try {
      data = JSON.parse(e.postData.contents);
    } catch (parseError) {
      return createErrorResponse("Format JSON invalide", "INVALID_JSON");
    }

    if (!data.nom_prenoms?.trim() || !data.date_naissance?.trim() || !data.contact?.trim()) {
      return createErrorResponse("Champs obligatoires manquants", "VALIDATION_ERROR");
    }

    var phonePattern = /^\+225[0-9]{10}$/;
    if (!phonePattern.test(data.contact.trim()) ||
        (data.contact_parent && data.contact_parent.trim() && !phonePattern.test(data.contact_parent.trim()))) {
      return createErrorResponse("Format téléphone invalide", "PHONE_VALIDATION_ERROR");
    }

    if (!data.lieu_naissance?.trim() || !data.profession?.trim() || !data.commune?.trim()) {
      return createErrorResponse("Informations du candidat incomplètes", "IDENTITY_VALIDATION_ERROR");
    }

    var communesAutorisees = ["Abobo", "Adjamé", "Cocody"];
    if (communesAutorisees.indexOf(data.commune.trim()) === -1) {
      return createErrorResponse("Commune non éligible (Abobo, Adjamé ou Cocody uniquement)", "COMMUNE_VALIDATION_ERROR");
    }

    if (!validateMinimumAge(data.date_naissance.trim(), 16)) {
      return createErrorResponse("Âge minimum requis : 16 ans révolus", "AGE_VALIDATION_ERROR");
    }

    if (!data.parent_tuteur?.trim() || !data.contact_parent?.trim()) {
      return createErrorResponse("Informations du parent ou tuteur manquantes", "GUARDIAN_VALIDATION_ERROR");
    }

    if (!data.preuve_paiement_base64?.trim()) {
      return createErrorResponse("Capture d'écran du paiement manquante", "PAYMENT_PROOF_REQUIRED");
    }

    var deadline = new Date("2026-09-30T00:00:00");
    if (new Date() >= deadline) {
      return createErrorResponse("Les pré-inscriptions sont closes", "DEADLINE_PASSED");
    }

    var sheet;
    try {
      sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
    } catch (sheetError) {
      return createErrorResponse("Erreur d'accès à la feuille", "SHEET_ACCESS_ERROR");
    }

    var sheetInfo = getSheetInfoOptimized(sheet);

    if (!sheetInfo.hasHeaders) {
      var headerResult = createHeadersOptimized(sheet);
      if (!headerResult.success) {
        return createErrorResponse("Erreur création en-têtes", "HEADER_ERROR");
      }
    }

    if (sheetInfo.hasData) {
      var duplicateCheck = checkForDuplicatesOptimized(sheet, data, sheetInfo.lastRow);
      if (duplicateCheck.isDuplicate) {
        return createErrorResponse(duplicateCheck.message, "DUPLICATE_ENTRY");
      }
    }

    var preuveUrl = savePaymentProof(
      data.preuve_paiement_base64,
      data.preuve_paiement_mime || "image/jpeg",
      data.preuve_paiement_nom || "preuve_paiement.jpg",
      sanitizeData(data.nom_prenoms)
    );

    if (!preuveUrl) {
      return createErrorResponse("Erreur lors de l'enregistrement de la preuve de paiement", "PAYMENT_PROOF_SAVE_ERROR");
    }

    var dateEnregistrement = new Date();
    var rowData = [
      sanitizeData(data.nom_prenoms),
      sanitizeData(data.date_naissance),
      sanitizeData(data.lieu_naissance),
      sanitizeData(data.profession),
      sanitizeData(data.commune),
      sanitizeData(data.contact),
      sanitizeData(data.parent_tuteur),
      sanitizeData(data.contact_parent),
      preuveUrl,
      dateEnregistrement
    ];

    sheet.appendRow(rowData);

    var executionTime = new Date().getTime() - startTime;
    Logger.log("Temps d'exécution: " + executionTime + "ms");

    return ContentService.createTextOutput(JSON.stringify({
      status: "success",
      message: "Préinscription enregistrée avec succès",
      preuveUrl: preuveUrl,
      row: sheet.getLastRow(),
      timestamp: dateEnregistrement.toISOString(),
      executionTime: executionTime + "ms"
    })).setMimeType(ContentService.MimeType.JSON);

  } catch (error) {
    Logger.log("ERREUR CRITIQUE: " + error.message);
    return createErrorResponse("Erreur interne du serveur", "INTERNAL_ERROR");
  }
}

function savePaymentProof(base64Data, mimeType, fileName, candidateName) {
  try {
    var allowedMimeTypes = ["image/jpeg", "image/jpg", "image/png", "image/webp"];
    if (allowedMimeTypes.indexOf(mimeType) === -1) {
      mimeType = "image/jpeg";
    }

    var safeName = candidateName.replace(/[^a-zA-Z0-9\s\-_]/g, "").trim().replace(/\s+/g, "_");
    if (!safeName) safeName = "candidat";
    var timestamp = Utilities.formatDate(new Date(), Session.getScriptTimeZone(), "yyyyMMdd_HHmmss");
    var extension = mimeType.indexOf("png") !== -1 ? "png" : (mimeType.indexOf("webp") !== -1 ? "webp" : "jpg");
    var finalName = "Preuve_" + safeName + "_" + timestamp + "." + extension;

    var folder = getOrCreateProofFolder();
    var blob = Utilities.newBlob(Utilities.base64Decode(base64Data), mimeType, finalName);
    var file = folder.createFile(blob);
    file.setSharing(DriveApp.Access.ANYONE_WITH_LINK, DriveApp.Permission.VIEW);

    return file.getUrl();
  } catch (error) {
    Logger.log("ERREUR savePaymentProof: " + error.message);
    return "";
  }
}

function getOrCreateProofFolder() {
  var folderName = "Preuves_Paiement_CRA_Abidjan1";
  var spreadsheet = SpreadsheetApp.getActiveSpreadsheet();
  var parentFolders = DriveApp.getFileById(spreadsheet.getId()).getParents();
  var parentFolder = parentFolders.hasNext() ? parentFolders.next() : DriveApp.getRootFolder();

  var folders = parentFolder.getFoldersByName(folderName);
  if (folders.hasNext()) {
    return folders.next();
  }

  return parentFolder.createFolder(folderName);
}

function validateMinimumAge(dateString, minAge) {
  try {
    var birthDate = new Date(dateString);
    var today = new Date();
    var age = today.getFullYear() - birthDate.getFullYear();
    var monthDiff = today.getMonth() - birthDate.getMonth();
    if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
      age--;
    }
    return age >= minAge;
  } catch (error) {
    return false;
  }
}

function createErrorResponse(message, errorCode) {
  Logger.log("Création réponse d'erreur: " + errorCode + " - " + message);
  return ContentService.createTextOutput(JSON.stringify({
    status: "error",
    message: message,
    errorCode: errorCode,
    timestamp: new Date().toISOString()
  })).setMimeType(ContentService.MimeType.JSON);
}

function getSheetInfoOptimized(sheet) {
  try {
    var lastRow = sheet.getLastRow();
    var lastColumn = sheet.getLastColumn();

    return {
      lastRow: lastRow,
      lastColumn: lastColumn,
      hasHeaders: lastRow > 0 && lastColumn >= 10,
      hasData: lastRow > 1
    };
  } catch (error) {
    Logger.log("ERREUR getSheetInfo: " + error.message);
    return {
      lastRow: 0,
      lastColumn: 0,
      hasHeaders: false,
      hasData: false
    };
  }
}

function createHeadersOptimized(sheet) {
  try {
    var headers = [
      "Nom et prénoms",
      "Date de naissance",
      "Lieu de naissance",
      "Profession",
      "Commune",
      "Contact",
      "Parent ou tuteur",
      "Contact parent/tuteur",
      "Preuve de paiement",
      "Date d'enregistrement"
    ];

    sheet.appendRow(headers);
    return { success: true };
  } catch (error) {
    Logger.log("ERREUR création en-têtes: " + error.message);
    return {
      success: false,
      message: "Erreur lors de la création des en-têtes: " + error.message
    };
  }
}

function checkForDuplicatesOptimized(sheet, data, lastRow) {
  try {
    if (lastRow <= 1) {
      return { isDuplicate: false };
    }

    var dataRange = sheet.getRange(2, 1, lastRow - 1, 6);
    var existingData = dataRange.getValues();

    var nomLower = data.nom_prenoms.toLowerCase().trim();
    var contactTrim = data.contact.trim();

    for (var i = 0; i < existingData.length; i++) {
      var row = existingData[i];
      if (row[0] && row[5]) {
        if (row[0].toString().toLowerCase().trim() === nomLower &&
            row[5].toString().trim() === contactTrim) {
          return {
            isDuplicate: true,
            message: "Une préinscription avec ces informations existe déjà"
          };
        }
      }
    }

    return { isDuplicate: false };
  } catch (error) {
    Logger.log("ERREUR vérification doublons: " + error.message);
    return { isDuplicate: false };
  }
}

function sanitizeData(input) {
  if (!input) return "";

  try {
    return input.toString()
      .trim()
      .replace(/[<>]/g, "")
      .substring(0, 500);
  } catch (error) {
    return "";
  }
}

function testConnection() {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
    sheet.getLastRow();
    return true;
  } catch (error) {
    return false;
  }
}

