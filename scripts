function doPost(e) {
  try {
    var startTime = new Date().getTime();
    Logger.log("=== DÉBUT DO POST ARBITRE ===");

    if (!e?.postData?.contents) {
      return createErrorResponse("Données manquantes", "MISSING_DATA");
    }

    if (e.postData.contents.length > 10000) {
      return createErrorResponse("Données trop volumineuses", "DATA_TOO_LARGE");
    }

    var data;
    try {
      data = JSON.parse(e.postData.contents);
    } catch (parseError) {
      return createErrorResponse("Format JSON invalide", "INVALID_JSON");
    }

    if (!data.nom?.trim() || !data.prenom?.trim() || !data.telephone?.trim() || !data.email?.trim()) {
      return createErrorResponse("Champs obligatoires manquants", "VALIDATION_ERROR");
    }

    var phonePattern = /^\+225[0-9]{10}$/;
    if (!phonePattern.test(data.telephone.trim())) {
      return createErrorResponse("Format téléphone invalide", "PHONE_VALIDATION_ERROR");
    }

    var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailPattern.test(data.email.trim())) {
      return createErrorResponse("Format email invalide", "EMAIL_VALIDATION_ERROR");
    }

    if (!data.sexe?.trim() || !data.date_naissance?.trim() || !data.profession?.trim()) {
      return createErrorResponse("Informations d'identité incomplètes", "IDENTITY_VALIDATION_ERROR");
    }

    if (!data.taille?.trim() || !data.poids?.trim()) {
      return createErrorResponse("Données physiques manquantes", "PHYSICAL_VALIDATION_ERROR");
    }

    if (!data.adresse?.trim()) {
      return createErrorResponse("Adresse manquante", "ADDRESS_VALIDATION_ERROR");
    }

    var sheet;
    try {
      sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
    } catch (sheetError) {
      return createErrorResponse("Erreur d'accès à la feuille", "SHEET_ACCESS_ERROR");
    }

    var sheetInfo = getSheetInfoOptimized(sheet);

    if (!sheetInfo.hasHeaders) {
      var headerResult = createHeadersOptimized(sheet);
      if (!headerResult.success) {
        return createErrorResponse("Erreur création en-têtes", "HEADER_ERROR");
      }
    }

    if (sheetInfo.hasData) {
      var duplicateCheck = checkForDuplicatesOptimized(sheet, data, sheetInfo.lastRow);
      if (duplicateCheck.isDuplicate) {
        return createErrorResponse(duplicateCheck.message, "DUPLICATE_ENTRY");
      }
    }

    var dateEnregistrement = new Date();
    var rowData = [
      sanitizeData(data.nom),
      sanitizeData(data.prenom),
      sanitizeData(data.sexe),
      sanitizeData(data.date_naissance),
      sanitizeData(data.profession),
      sanitizeData(data.taille),
      sanitizeData(data.poids),
      sanitizeData(data.adresse),
      sanitizeData(data.telephone),
      sanitizeData(data.email),
      dateEnregistrement
    ];

    sheet.appendRow(rowData);

    var executionTime = new Date().getTime() - startTime;
    Logger.log("Temps d'exécution: " + executionTime + "ms");

    return ContentService.createTextOutput(JSON.stringify({
      status: "success",
      message: "Préinscription enregistrée avec succès",
      row: sheet.getLastRow(),
      timestamp: dateEnregistrement.toISOString(),
      executionTime: executionTime + "ms"
    })).setMimeType(ContentService.MimeType.JSON);

  } catch (error) {
    Logger.log("ERREUR CRITIQUE: " + error.message);
    return createErrorResponse("Erreur interne du serveur", "INTERNAL_ERROR");
  }
}

function createErrorResponse(message, errorCode) {
  Logger.log("Création réponse d'erreur: " + errorCode + " - " + message);
  return ContentService.createTextOutput(JSON.stringify({
    status: "error",
    message: message,
    errorCode: errorCode,
    timestamp: new Date().toISOString()
  })).setMimeType(ContentService.MimeType.JSON);
}

function getSheetInfoOptimized(sheet) {
  try {
    var lastRow = sheet.getLastRow();
    var lastColumn = sheet.getLastColumn();

    return {
      lastRow: lastRow,
      lastColumn: lastColumn,
      hasHeaders: lastRow > 0 && lastColumn >= 11,
      hasData: lastRow > 1
    };
  } catch (error) {
    Logger.log("ERREUR getSheetInfo: " + error.message);
    return {
      lastRow: 0,
      lastColumn: 0,
      hasHeaders: false,
      hasData: false
    };
  }
}

function createHeadersOptimized(sheet) {
  try {
    var headers = [
      "Nom",
      "Prénoms",
      "Sexe",
      "Date de naissance",
      "Profession",
      "Taille (cm)",
      "Poids (kg)",
      "Adresse géographique",
      "Téléphone",
      "Email",
      "Date d'enregistrement"
    ];

    sheet.appendRow(headers);
    return { success: true };
  } catch (error) {
    Logger.log("ERREUR création en-têtes: " + error.message);
    return {
      success: false,
      message: "Erreur lors de la création des en-têtes: " + error.message
    };
  }
}

function checkForDuplicatesOptimized(sheet, data, lastRow) {
  try {
    if (lastRow <= 1) {
      return { isDuplicate: false };
    }

    var dataRange = sheet.getRange(2, 1, lastRow - 1, 10);
    var existingData = dataRange.getValues();

    var nomLower = data.nom.toLowerCase().trim();
    var prenomLower = data.prenom.toLowerCase().trim();
    var telephoneTrim = data.telephone.trim();
    var emailLower = data.email.toLowerCase().trim();

    for (var i = 0; i < existingData.length; i++) {
      var row = existingData[i];
      if (row[0] && row[1] && row[8]) {
        if (row[0].toString().toLowerCase().trim() === nomLower &&
            row[1].toString().toLowerCase().trim() === prenomLower &&
            row[8].toString().trim() === telephoneTrim) {
          return {
            isDuplicate: true,
            message: "Une préinscription avec ces informations existe déjà"
          };
        }
      }

      if (row[9] && row[9].toString().toLowerCase().trim() === emailLower) {
        return {
          isDuplicate: true,
          message: "Cet email est déjà enregistré"
        };
      }
    }

    return { isDuplicate: false };
  } catch (error) {
    Logger.log("ERREUR vérification doublons: " + error.message);
    return { isDuplicate: false };
  }
}

function sanitizeData(input) {
  if (!input) return "";

  try {
    return input.toString()
      .trim()
      .replace(/[<>]/g, "")
      .substring(0, 500);
  } catch (error) {
    return "";
  }
}

function testConnection() {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
    sheet.getLastRow();
    return true;
  } catch (error) {
    return false;
  }
}

function doOptions(e) {
  return ContentService.createTextOutput("")
    .setMimeType(ContentService.MimeType.TEXT);
}

function doGet(e) {
  try {
    var startTime = new Date().getTime();

    if (!testConnection()) {
      return createErrorResponse("Erreur de connexion", "CONNECTION_ERROR");
    }

    var executionTime = new Date().getTime() - startTime;

    return ContentService.createTextOutput(JSON.stringify({
      status: "success",
      message: "API préinscription arbitres CRA Abidjan 1",
      timestamp: new Date().toISOString(),
      version: "1.0",
      fields: {
        total: 11,
        columns: [
          "Nom",
          "Prénoms",
          "Sexe",
          "Date de naissance",
          "Profession",
          "Taille (cm)",
          "Poids (kg)",
          "Adresse géographique",
          "Téléphone",
          "Email",
          "Date d'enregistrement"
        ]
      },
      performance: {
        executionTime: executionTime + "ms"
      }
    })).setMimeType(ContentService.MimeType.JSON);

  } catch (error) {
    return createErrorResponse("Erreur interne du serveur", "INTERNAL_ERROR");
  }
}
